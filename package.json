{
  "name": "mptool-root",
  "private": true,
  "description": "Miniapp is a lightweight framework for QQ/Wechat miniapp.",
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": "https://github.com/miniapp-tool/mptool",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production pnpm --stream -r run build",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 2",
    "clean": "pnpm --stream -r run clean",
    "copy": "unrun scripts/copy-package.ts",
    "dev": "cross-env NODE_ENV=production pnpm --stream -r run dev",
    "docs:build": "pnpm --dir=docs run docs:build",
    "docs:dev": "pnpm --dir=docs run docs:dev",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "packages:update": "pnpm dlx npm-check-updates -u --deep",
    "postinstall": "husky",
    "release": "pnpm run clean && pnpm run build && pnpm run release:version && pnpm run release:publish && pnpm run release:sync",
    "release:publish": "lerna publish from-package --yes",
    "release:sync": " unrun scripts/sync.ts",
    "release:version": "lerna version",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "1.9.1",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@lerna-lite/cli": "5.0.0",
    "@lerna-lite/publish": "5.0.0",
    "@mr-hope/tsconfig": "0.0.3",
    "@types/node": "^24.12.2",
    "@vitest/coverage-istanbul": "4.1.4",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cross-env": "10.1.0",
    "husky": "9.1.7",
    "miniprogram-api-typings": "5.1.2",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.1.6",
    "oxfmt": "0.45.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "tsdown": "0.21.9",
    "typescript": "6.0.3",
    "unrun": "0.2.36",
    "vitest": "4.1.4"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "packageManager": "pnpm@10.33.0"
}
