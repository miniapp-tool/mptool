{
  "name": "@mptool/skyline",
  "version": "0.13.0",
  "description": "Full pack for mptool",
  "keywords": [
    "miniapp",
    "miniprogram"
  ],
  "homepage": "https://github.com/miniapp-tool/mptool/tree/main/packages/all#readme",
  "bugs": {
    "url": "https://github.com/miniapp-tool/mptool/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/miniapp-tool/mptool.git",
    "directory": "packages/all"
  },
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "default": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf ./dist"
  },
  "devDependencies": {
    "@mptool/file": "workspace:*",
    "@mptool/net": "workspace:*",
    "@mptool/parser": "workspace:*",
    "@mptool/skyline-enhance": "workspace:*",
    "miniprogram-api-typings": "5.1.2"
  },
  "peerDependencies": {
    "miniprogram-api-typings": "^5.0.0"
  }
}
