{
  "name": "@mptool/net",
  "version": "0.12.1",
  "description": "Network api for QQ/Wechat miniapp",
  "keywords": [
    "cookie",
    "miniapp",
    "miniprogram",
    "network"
  ],
  "homepage": "https://github.com/miniapp-tool/mptool/tree/main/packages/net#readme",
  "bugs": {
    "url": "https://github.com/miniapp-tool/mptool/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/miniapp-tool/mptool.git",
    "directory": "packages/net"
  },
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "default": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf ./dist"
  },
  "dependencies": {
    "@mptool/shared": "workspace:*"
  },
  "devDependencies": {
    "@mptool/mock": "workspace:*",
    "@types/set-cookie-parser": "2.4.10",
    "miniprogram-api-typings": "5.1.2",
    "set-cookie-parser": "3.1.0"
  },
  "peerDependencies": {
    "miniprogram-api-typings": "^5.0.0"
  }
}
